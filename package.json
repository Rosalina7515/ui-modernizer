{
  "name": "ui-modernizer",
  "version": "0.6.0",
  "description": "One-prompt UI modernization for React/Vue/Svelte + Tailwind. A Claude Code Skill that upgrades your UI to 2026 SaaS-grade design (Linear / Vercel / Stripe / shadcn).",
  "type": "module",
  "bin": {
    "ui-modernizer": "./bin/install.mjs"
  },
  "scripts": {
    "install-skill": "node bin/install.mjs",
    "demo:before": "cd examples/before && npm install && npm run dev",
    "demo:after": "cd examples/after && npm install && npm run dev"
  },
  "files": [
    "SKILL.md",
    "bin",
    "references",
    "scripts",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "skill",
    "ai",
    "ui",
    "design",
    "tailwind",
    "react",
    "nextjs",
    "vue",
    "nuxt",
    "svelte",
    "sveltekit",
    "modernize",
    "refactor",
    "shadcn",
    "design-system"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rosalina7515/ui-modernizer"
  },
  "homepage": "https://github.com/Rosalina7515/ui-modernizer#readme",
  "optionalDependencies": {
    "playwright": "^1.48.0",
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/generator": "^7.25.0",
    "sharp": "^0.33.5"
  }
}
